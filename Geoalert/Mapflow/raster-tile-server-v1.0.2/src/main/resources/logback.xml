<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{"yyyy-MM-dd'T'HH:mm:ss,SSS"} [%thread] %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="io.geoalert" level="${LOG_LEVEL:-INFO}"/>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
